{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://renn.example.com/world.json",
  "title": "RennWorld",
  "description": "3D game world with physics, entities, assets, and scripts",
  "type": "object",
  "required": ["version", "world", "entities"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "world": { "$ref": "#/$defs/WorldSettings" },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/Entity" },
      "minItems": 0
    },
    "assets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/AssetRef" }
    },
    "scripts": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/ScriptDef" }
    },
    "transformers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/TransformerDef" },
      "description": "World-level transformer registry. entity.transformers holds IDs into this map."
    },
    "transformerPipes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/TransformerPipe" },
      "description": "Named reusable transformer pipelines."
    },
    "groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/EntityGroup" },
      "description": "Optional explorer groups (Phase A: organizational only). Members may be entity or sub-group IDs."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "Rotation": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "Euler angles in radians [x, y, z]"
    },
    "Color": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 4
    },
    "SleepingSettings": {
      "type": "object",
      "description": "Custom sleep thresholds: body sleeps after velocities stay below thresholds for timeUntilSleep seconds. Negative linearThreshold or angularThreshold disables that axis check (Rapier-style).",
      "required": ["linearThreshold", "angularThreshold", "timeUntilSleep"],
      "properties": {
        "linearThreshold": {
          "type": "number",
          "description": "Max linear speed magnitude (length units/s) to count as at rest; negative disables linear check"
        },
        "angularThreshold": {
          "type": "number",
          "description": "Max angular speed magnitude (rad/s) to count as at rest; negative disables angular check"
        },
        "timeUntilSleep": {
          "type": "number",
          "description": "Seconds both checks must pass continuously before body.sleep()"
        }
      },
      "additionalProperties": false
    },
    "DistanceCullingSettings": {
      "type": "object",
      "required": ["maxDistance", "minSizeDistanceRatio"],
      "properties": {
        "maxDistance": {
          "type": "number",
          "minimum": 0.1,
          "description": "Cull when camera–object distance exceeds this (world units)"
        },
        "minSizeDistanceRatio": {
          "type": "number",
          "minimum": 0.0001,
          "description": "Cull when worldSize/distance is below this ratio (squared test in engine)"
        },
        "sleepCulled": {
          "type": "boolean",
          "description": "Disable physics and skip scripts for culled entities"
        }
      },
      "additionalProperties": false
    },
    "FogSettings": {
      "type": "object",
      "description": "Linear distance fog (Three.js Fog). Omitted color uses skyColor at runtime.",
      "properties": {
        "color": { "$ref": "#/$defs/Color" },
        "near": {
          "type": "number",
          "minimum": 0,
          "description": "Distance where fog begins (world units)"
        },
        "far": {
          "type": "number",
          "minimum": 0.01,
          "description": "Distance where fog is fully opaque (world units)"
        }
      },
      "additionalProperties": false
    },
    "SimulationSettings": {
      "type": "object",
      "description": "Semi-fixed timestep: fixedDt physics step, max catch-up steps per render frame, and time scale",
      "properties": {
        "fixedDt": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Simulation step in seconds (e.g. 1/60 for 60 Hz); runtime clamps to ~15–240 Hz"
        },
        "maxStepsPerFrame": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Max physics steps per rAF tick (spiral-of-death guard)"
        },
        "timeScale": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 5,
          "description": "Simulation speed multiplier (1 = real time, 2 = double speed, 0.5 = slow motion); runtime clamps to 0.1–5"
        }
      },
      "additionalProperties": false
    },
    "WorldSettings": {
      "type": "object",
      "properties": {
        "gravity": { "$ref": "#/$defs/Vec3" },
        "wind": { "$ref": "#/$defs/Vec3", "description": "Global wind force vector [x, y, z]" },
        "sleeping": { "$ref": "#/$defs/SleepingSettings" },
        "sound": { "$ref": "#/$defs/SoundSettings" },
        "ambientLight": { "$ref": "#/$defs/Color" },
        "directionalLight": { "$ref": "#/$defs/DirectionalLightConfig" },
        "skyColor": { "$ref": "#/$defs/Color" },
        "skybox": { "type": "string" },
        "fog": {
          "description": "Omitted or false = disabled. Object = linear distance fog.",
          "oneOf": [
            { "type": "boolean", "enum": [false] },
            { "$ref": "#/$defs/FogSettings" }
          ]
        },
        "camera": { "$ref": "#/$defs/CameraConfig" },
        "simulation": { "$ref": "#/$defs/SimulationSettings" },
        "showFrameStats": {
          "type": "boolean",
          "description": "Overlay last-frame timing / fps on the scene canvas"
        },
        "logarithmicDepthBuffer": {
          "type": "boolean",
          "description": "When false, WebGLRenderer uses linear depth only. Omitted or true: logarithmic depth (default) for better intersection stability at distance"
        },
        "renderPixelRatio": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "WebGL canvas pixel density. low=1×, medium=min(dpr,1.5) (default), high=min(dpr,2)"
        },
        "shadowsEnabled": {
          "type": "boolean",
          "description": "When false, disables directional-light shadow maps on the renderer. Omitted or true: enabled (default)"
        },
        "videoTextureMaxAnisotropy": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "description": "VideoTexture.anisotropy for material video maps (1–16); omitted defaults to 16"
        },
        "distanceCulling": {
          "description": "Omitted = engine defaults (enabled). false = disabled.",
          "oneOf": [
            { "type": "boolean", "enum": [false] },
            { "$ref": "#/$defs/DistanceCullingSettings" }
          ]
        }
      },
      "additionalProperties": false
    },
    "SoundSettings": {
      "type": "object",
      "properties": {
        "assetId": { "type": "string" },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "loop": { "type": "boolean" },
        "autoplay": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "DirectionalLightConfig": {
      "type": "object",
      "properties": {
        "direction": { "$ref": "#/$defs/Vec3" },
        "color": { "$ref": "#/$defs/Color" },
        "intensity": { "type": "number" }
      },
      "additionalProperties": false
    },
    "EditorFreePose": {
      "type": "object",
      "required": ["position", "quaternion"],
      "properties": {
        "position": { "$ref": "#/$defs/Vec3" },
        "quaternion": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        }
      },
      "additionalProperties": false
    },
    "CameraConfig": {
      "type": "object",
      "properties": {
        "control": { "enum": ["free", "follow", "top", "front", "right"] },
        "mode": { "enum": ["firstPerson", "thirdPerson", "follow", "tracking"] },
        "target": { "type": "string" },
        "distance": { "type": "number" },
        "height": { "type": "number" },
        "targetVerticalAngle": {
          "type": "number",
          "description": "Degrees; vertical look-at offset relative to camera–target distance (positive tilts view up so subject sits lower in frame)"
        },
        "fov": { "type": "number" },
        "defaultPosition": { "$ref": "#/$defs/Vec3" },
        "defaultRotation": { "$ref": "#/$defs/Rotation" },
        "editorFreePose": { "$ref": "#/$defs/EditorFreePose" }
      },
      "additionalProperties": false
    },
    "EntityAvatarConfig": {
      "type": "object",
      "description": "Marks entity as a playable avatar (keyboard/script switch); preferredCamera is optional defaults when focusing this avatar",
      "properties": {
        "enabled": { "type": "boolean" },
        "preferredCamera": {
          "type": "object",
          "properties": {
            "control": { "enum": ["free", "follow", "top", "front", "right"] },
            "mode": { "enum": ["firstPerson", "thirdPerson", "follow", "tracking"] },
            "target": { "type": "string" },
            "distance": { "type": "number" },
            "height": { "type": "number" },
            "targetVerticalAngle": { "type": "number" },
            "fov": { "type": "number" },
            "defaultPosition": { "$ref": "#/$defs/Vec3" },
            "defaultRotation": { "$ref": "#/$defs/Rotation" },
            "editorFreePose": { "$ref": "#/$defs/EditorFreePose" },
            "orbitYaw": { "type": "number" },
            "orbitPitch": { "type": "number" },
            "orbitDistance": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "AssetRef": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "type": { "enum": ["texture", "model", "cubeTexture", "audio", "video"] }
      },
      "additionalProperties": false
    },
    "Shape": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "width", "height", "depth"],
          "properties": {
            "type": { "const": "box" },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "depth": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "radius"],
          "properties": {
            "type": { "const": "sphere" },
            "radius": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "radius", "height"],
          "properties": {
            "type": { "const": "cylinder" },
            "radius": { "type": "number" },
            "height": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "radius", "height"],
          "properties": {
            "type": { "const": "capsule" },
            "radius": { "type": "number" },
            "height": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "radius", "height"],
          "properties": {
            "type": { "const": "cone" },
            "radius": { "type": "number" },
            "height": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "baseSize", "height"],
          "properties": {
            "type": { "const": "pyramid" },
            "baseSize": { "type": "number" },
            "height": { "type": "number" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "plane" },
            "normal": { "$ref": "#/$defs/Vec3" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "model"],
          "properties": {
            "type": { "const": "trimesh" },
            "model": { "type": "string" },
            "simplification": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "maxTriangles": { "type": "number", "minimum": 500 },
                "targetReduction": { "type": "number", "minimum": 0, "maximum": 1 },
                "algorithm": { "enum": ["meshoptimizer", "simplifyModifier"] },
                "maxError": { "type": "number", "minimum": 0.0001 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "MaterialRef": {
      "type": "object",
      "properties": {
        "color": { "$ref": "#/$defs/Color" },
        "map": { "type": "string" },
        "roughness": { "type": "number" },
        "metalness": { "type": "number" },
        "opacity": { "type": "number", "description": "Opacity 0..1 (renderer clamps; default 1)" },
        "mapRepeat": { "$ref": "#/$defs/Vec3" },
        "mapWrapS": { "enum": ["repeat", "clampToEdge", "mirroredRepeat"] },
        "mapWrapT": { "enum": ["repeat", "clampToEdge", "mirroredRepeat"] },
        "mapRotation": { "type": "number" },
        "mapOffset": { "$ref": "#/$defs/Vec3" }
      },
      "additionalProperties": false
    },
    "ScriptDef": {
      "oneOf": [
        {
          "type": "object",
          "required": ["event", "source"],
          "properties": {
            "event": { "enum": ["onSpawn", "onUpdate", "onCollision"] },
            "source": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["event", "interval", "source"],
          "properties": {
            "event": { "const": "onTimer" },
            "interval": { "type": "number", "exclusiveMinimum": 0 },
            "source": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "EntityScripts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Script IDs referring to world.scripts"
    },
    "InputMapping": {
      "type": "object",
      "properties": {
        "keyboard": {
          "type": "object",
          "properties": {
            "w": { "type": "string" },
            "a": { "type": "string" },
            "s": { "type": "string" },
            "d": { "type": "string" },
            "space": { "type": "string" },
            "shift": { "type": "string" }
          },
          "additionalProperties": false
        },
        "wheel": {
          "type": "object",
          "properties": {
            "horizontal": { "type": "string" },
            "vertical": { "type": "string" }
          },
          "additionalProperties": false
        },
        "sensitivity": {
          "type": "object",
          "properties": {
            "keyboard": { "type": "number" },
            "wheel": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "TransformerConfig": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Built-in preset types: input, car2, person, targetPoseInput, kinematicMovement, wanderer, follow (see transformerRegistry). Other strings are accepted for forward compatibility."
        },
        "name": {
          "type": "string",
          "description": "Optional label for custom transformers (used in the Transformer code tab; unique among custom entries on the same entity)."
        },
        "priority": {
          "type": "number",
          "description": "Execution order (lower = earlier), default: 10"
        },
        "enabled": {
          "type": "boolean",
          "description": "Enable/disable transformer, default: true"
        },
        "inputMapping": {
          "$ref": "#/$defs/InputMapping",
          "description": "Custom input mapping (only for input transformer)"
        },
        "params": {
          "type": "object",
          "additionalProperties": true,
          "description": "Transformer-specific parameters"
        },
        "code": {
          "type": "string",
          "description": "Custom transformer code (JavaScript, only for type 'custom')"
        }
      },
      "additionalProperties": false
    },
    "TransformerDef": {
      "$ref": "#/$defs/TransformerConfig",
      "description": "World-level transformer definition (mirrors TransformerConfig; stored in world.transformers registry keyed by ID)."
    },
    "Entity": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bodyType": { "enum": ["static", "dynamic", "kinematic"] },
        "shape": { "$ref": "#/$defs/Shape" },
        "position": { "$ref": "#/$defs/Vec3" },
        "rotation": { "$ref": "#/$defs/Rotation" },
        "scale": { "$ref": "#/$defs/Vec3" },
        "model": { "type": "string" },
        "modelRotation": { "$ref": "#/$defs/Rotation", "description": "Euler radians applied to model/trimesh only" },
        "modelScale": { "$ref": "#/$defs/Vec3", "description": "Scale applied to model/trimesh only" },
        "showShapeWireframe": {
          "type": "boolean",
          "description": "Outline physics primitive when entity.model is set (not trimesh); not GLTF wireframe"
        },
        "modelSimplification": {
          "type": "object",
          "description": "Visual decimation for entity.model on a primitive; trimesh uses shape.simplification",
          "properties": {
            "enabled": { "type": "boolean" },
            "maxTriangles": { "type": "number", "minimum": 500 },
            "targetReduction": { "type": "number", "minimum": 0, "maximum": 1 },
            "algorithm": { "enum": ["meshoptimizer", "simplifyModifier"] },
            "maxError": { "type": "number", "minimum": 0.0001 }
          },
          "additionalProperties": false
        },
        "doubleSided": {
          "type": "boolean",
          "description": "When true, drawable GLTF materials use THREE.DoubleSide. When omitted, sides follow source materials (stored clones)."
        },
        "material": { "$ref": "#/$defs/MaterialRef" },
        "mass": { "type": "number" },
        "restitution": { "type": "number" },
        "friction": { "type": "number" },
        "linearDamping": { "type": "number" },
        "angularDamping": { "type": "number" },
        "scripts": { "$ref": "#/$defs/EntityScripts" },
        "locked": { "type": "boolean" },
        "transformers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Transformer IDs referencing world.transformers registry"
        },
        "transformerPipeStack": {
          "type": "array",
          "items": { "$ref": "#/$defs/TransformerPipeBinding" },
          "description": "Ordered pipe instances (pipe stack). entity.transformers is the flattened runtime cache."
        },
        "transformerPipe": {
          "type": "string",
          "description": "Deprecated: migrated to transformerPipeStack on load"
        },
        "avatar": { "$ref": "#/$defs/EntityAvatarConfig" }
      },
      "additionalProperties": false
    },
    "EntityGroup": {
      "type": "object",
      "required": ["id", "memberIds"],
      "description": "Phase A: organizational only — no runtime effect. Phase B reserves the optional `rig` field for joint configuration.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "memberIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered IDs of member entities or sub-groups"
        },
        "collapsed": { "type": "boolean", "description": "Explorer UI fold state" },
        "rig": {
          "type": "object",
          "description": "Phase B placeholder: rig/joint configuration. Phase A round-trips opaquely.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "TransformerPipeBinding": {
      "type": "object",
      "required": ["pipeId"],
      "properties": {
        "pipeId": { "type": "string" },
        "params": {
          "type": "object",
          "additionalProperties": true,
          "description": "Per-entity pipe input overrides for stack-root pipe scopes"
        },
        "scopeParams": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          },
          "description": "Per-entity overrides keyed by pipe-nav scope path (nested pipe instances)"
        },
        "mode": {
          "type": "string",
          "enum": ["linked", "copy"],
          "description": "Copy bindings use entity-local stage clones"
        },
        "enabled": { "type": "boolean" },
        "localStageIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "TransformerPipeMember": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "stageId"],
          "properties": {
            "kind": { "const": "stage" },
            "stageId": { "type": "string" },
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "pipeId"],
          "properties": {
            "kind": { "const": "pipe" },
            "pipeId": { "type": "string" },
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "PipeParamDef": {
      "type": "object",
      "required": ["key", "type"],
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["number", "string", "boolean", "entityId", "vec3"]
        },
        "default": {},
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "TransformerPipe": {
      "type": "object",
      "required": ["id", "name", "stageIds", "stages"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "stageIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Leaf stage registry IDs (legacy flat list)"
        },
        "stages": {
          "type": "array",
          "items": { "$ref": "#/$defs/TransformerConfig" },
          "description": "Leaf stage snapshots (copy template)"
        },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/TransformerPipeMember" },
          "description": "Manifold member order: stages and/or nested pipes"
        },
        "paramDefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/PipeParamDef" }
        },
        "paramBindings": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "createdAt": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}
