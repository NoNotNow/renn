    "@monaco-editor/react": "^4.7.0",
    "acorn": "^8.16.0",
    "ajv": "^8.17.1",
    "idb": "^8.0.0",
    "jszip": "^3.10.1",
    "meshoptimizer": "^1.0.1",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.170.0",
