  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:perf": "RUN_PERF_BENCHMARKS=1 vitest run src/test/scenarios/performance-benchmarks.integration.test.ts",
